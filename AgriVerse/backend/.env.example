# MongoDB Atlas connection string
# Example: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/agriverse?retryWrites=true&w=majority
MONGO_URI=your_mongodb_atlas_connection_string_here

# Port for the backend server
PORT=5000

# Secret used to sign admin JWT tokens - change this to a long random string
JWT_SECRET=replace_this_with_a_long_random_secret

# Token expiry
JWT_EXPIRES_IN=7d

# Default admin seed credentials (used by seed.js)
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=admin123

# Comma-separated list of origins allowed to call this API
CLIENT_ORIGIN=http://localhost:5173
